# Copie para .env e ajuste conforme necessário: cp .env.example .env

# Banco de dados
DB_NAME=hackton
DB_PORT=3306
DB_PASSWORD=root

# Aplicação
APP_PORT=8080

# Segurança JWT (use um segredo forte, com pelo menos 256 bits, em produção)
JWT_SECRET=hackton-sus-development-secret-key-with-at-least-256-bits
JWT_EXPIRATION_MINUTES=120

# Usuário administrador criado na primeira inicialização
APP_ADMIN_EMAIL=admin@sus.local
APP_ADMIN_PASSWORD=admin123
